def linear_search(arr, target):
      for i in range(len(arr)):
          if arr[i] == target:
              return i
      return -1
  
arr = ['Rice','Sugar','Milk','Oil','Soap']
target = input("Enter the target value")
result = linear_search(arr, target)
  
if result != -1:
    print("product found")
else:
    print("product not found")
  
